# Vercel / production: FastAPI on Render (no trailing slash).
# Vite injects only vars prefixed with VITE_.
#
# VITE_API_URL=https://project-backend-bq4f.onrender.com
#
# Local dev: Vite proxies /api, /inflow, /ledger, /outflow to FastAPI (default port 8000).
# If Django already uses 8000, run FastAPI on 8001 and set:
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8001
