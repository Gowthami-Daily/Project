# Copy to ".env" in this folder (backend/) and fill in values. Never commit ".env".

# --- Database ---
# Omit DATABASE_URL to use local SQLite (gowthami_inflow.db).
#
# From Render PostgreSQL → Connections:
# - Local dev / laptop: use "External Database URL" and append SSL:
#   DATABASE_URL=postgresql://USER:PASSWORD@dpg-xxxxx.REGION-postgres.render.com/DATABASE?sslmode=require
# - FastAPI on Render (same region as DB): "Internal Database URL" works without sslmode.
#
# The app rewrites postgresql:// to postgresql+psycopg2:// automatically (psycopg2-binary).
#
# Empty PostgreSQL (e.g. new Render instance): from backend/, run
#   .venv\Scripts\python.exe init_db.py
# then for Django admin/auth/sessions:
#   .venv\Scripts\python.exe manage.py migrate

# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# --- JWT (set in production) ---
# SECRET_KEY=
